# Copy this file to .env and fill in your keys.
# Never commit .env to git.

# Your name — Elfie uses this in greetings ("Hey Alex, I'm here.")
OWNER_NAME=

# LiveKit — room / WebRTC layer
# Cloud: https://cloud.livekit.io  |  Local: ws://localhost:7880
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram — speech-to-text  (https://console.deepgram.com)
DEEPGRAM_API_KEY=

# Groq — LLM inference, very cheap  (https://console.groq.com)
GROQ_API_KEY=

# Cartesia — text-to-speech  (https://play.cartesia.ai/console)
CARTESIA_API_KEY=

# --- Optional ---------------------------------------------------------------

# Telegram report delivery — reports also land on your phone.
# Create a bot with @BotFather, then message it once and get your chat id
# from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Delegation — background tasks run via Claude Code headless on this machine.
# CLAUDE_PATH=claude
# CLAUDE_PERMISSION_MODE=acceptEdits

# Dashboard port (http://localhost:8765)
# DASHBOARD_PORT=8765

# Gmail — lets Elfie check/read your unread email by voice.
# Create an app password at https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Brave Search skill — better web results (free: api.search.brave.com)
BRAVE_API_KEY=
